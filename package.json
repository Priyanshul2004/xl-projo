{
  "name": "excel-mapping-app",
  "version": "1.0.0",
  "description": "Excel file mapping and processing web application",
  "main": "Backend/src/server.js",
  "scripts": {
    "frontend:install": "npm install --prefix Frontend",
    "frontend:dev": "npm run dev --prefix Frontend",
    "frontend:build": "npm run build --prefix Frontend",
    "build": "npm run frontend:build",
    "start": "node Backend/src/server.js",
    "dev:backend": "nodemon Backend/src/server.js",
    "dev": "npm run dev:all",
    "dev:all": "concurrently \"npm run dev:backend\" \"npm run frontend:dev\"",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "exceljs": "^4.4.0",
    "express": "^4.18.2",
    "fs-extra": "^11.1.1",
    "http-proxy-middleware": "^4.0.0",
    "multer": "^1.4.5-lts.1",
    "path": "^0.12.7",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "concurrently": "^10.0.3",
    "nodemon": "^3.1.14"
  },
  "keywords": [
    "excel",
    "mapping",
    "file-processing",
    "mvc"
  ],
  "author": "",
  "license": "ISC"
}
